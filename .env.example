# Telegram — токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Allowlist пользователей через Shectory Portal (таблица в БД портала; правка: /projects/shectory-assist/control).
# Задайте оба значения — тогда бот подтянет список с портала. Секрет — тот же, что SHECTORY_AUTH_BRIDGE_SECRET в .env портала.
# PORTAL_ALLOWLIST_BASE_URL=https://shectory.ru
# SHECTORY_AUTH_BRIDGE_SECRET=
# PORTAL_ALLOWLIST_PROJECT_SLUG=shectory-assist
# PORTAL_ALLOWLIST_CACHE_MS=60000
# PORTAL_ALLOWLIST_FAIL_OPEN=true
# PORTAL_ALLOWLIST_TIMEOUT_MS=8000

# Секрет webhook: то же значение, что передаёшь в setWebhook как secret_token (заголовок X-Telegram-Bot-Api-Secret-Token). Для long poll можно пусто.
# TELEGRAM_WEBHOOK_SECRET=

# --- Gemini: те же переменные, что в Ourdiary (`docs/ADR/0002-gemini-agent-env-proxy.md`) ---
AGENT_LLM_API_KEY=

# На многих серверах в РФ api.telegram.org недоступен без прокси — задай тот же AGENT_PROXY, что для Gemini.
# AGENT_PROXY=http://user:pass@host:port
# AGENT_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# AGENT_LLM_TIMEOUT_MS=45000
# AGENT_PROXY_CONNECT_TIMEOUT_MS=30000
# AGENT_LLM_MODEL=gemini-2.5-flash
# AGENT_LLM_MODEL_FAST=gemini-2.5-flash
# AGENT_GEMINI_ASR_MODEL=gemini-2.5-flash
# AGENT_GEMINI_NLU_MODEL=gemini-2.5-flash
AGENT_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Режим: long_poll (по умолчанию) или webhook
BOT_MODE=long_poll
PORT=8080

DEFAULT_TTS_VOICE=Kore
RATE_LIMIT_PER_USER_PER_MIN=12

GAZETA_USER_AGENT=ShectoryAssist/0.1 (+https://example.com/contact)
GAZETA_CACHE_TTL_MS=90000
GAZETA_MAX_FETCH_PER_MIN=8
GAZETA_MAX_TITLES=15
